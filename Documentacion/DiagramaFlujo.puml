@startuml DiagramaFlujo_SancarlitaAcademy

title Sancarlista Academy - Diagrama de Flujo Principal

skinparam backgroundColor #FEFEFE
skinparam ArrowColor #333333
skinparam ActivityBorderColor #555555
skinparam ActivityBackgroundColor #D6EAF8
skinparam ActivityDiamondBackgroundColor #FDEBD0

start

:Iniciar sistema;
:Cargar datos desde datos.ser;

:Pantalla de Login;
:Ingresar codigo y contrasena;

if (Credenciales validas?) then (Si)
  :Registrar INICIO_SESION EXITO en Bitacora;
  :Aumentar usuarios activos;
  if (Rol del usuario?) then (Administrador)

    :Panel Administrador;
    :Iniciar 3 hilos\n(Sesiones, Inscripciones, Estadisticas);

    fork
      :Hilo Sesiones\ncada 5 seg;
    fork again
      :Hilo Estadisticas\ncada 10 seg;
    fork again
      repeat
        :Hilo Inscripciones\nespera 8 seg;
        if (Hay inscripciones pendientes?) then (Si)
          :Mover inscripcion\na Confirmadas;
        else (No)
        endif
      repeat while (Hilo activo?)
    end fork

    :Administrador opera el sistema;

    fork
      :CRUD Instructores / Estudiantes / Cursos;
      :Validar: codigo no vacio, no duplicado;
      if (Datos validos?) then (Si)
        :Guardar en arreglo;
        :Guardar sistema (datos.ser);
        :Registrar operacion en Bitacora;
      else (No)
        :Mostrar mensaje de error;
      endif
    fork again
      :Asignar instructor a curso;
      :Guardar sistema;
    fork again
      :Generar reporte PDF;
      :Guardar archivo en carpeta raiz;
    fork again
      :Filtrar / Exportar Bitacora;
    end fork

  else if (Rol del usuario?) then (Instructor)

    :Panel Instructor;
    :Mostrar cursos asignados al instructor;

    :Gestionar notas de estudiantes;
    if (Datos de nota validos?\nponderacion>0, nota 0-100\nno duplicado) then (Si)
      :Guardar nota;
      :Recalcular promedio ponderado;
      :Mostrar Aprobado (>=61) o Reprobado;
    else (No)
      :Mostrar mensaje de error;
    endif

  else (Estudiante)

    :Panel Estudiante;
    :Mostrar cursos disponibles con estado;

    if (Accion del estudiante?) then (Inscribirse)
      if (Ya inscrito en ese curso?) then (Si)
        :Mostrar error: ya inscrito;
      else if (Choque de seccion?) then (Si)
        :Mostrar error: choque de horario;
      else (No)
        :Agregar a cola de pendientes;
        :Estado del curso = Pendiente;
        :Guardar sistema;
      endif
    else if (Accion del estudiante?) then (Desasignar)
      if (Esta inscrito o pendiente?) then (Si)
        :Eliminar inscripcion del arreglo;
        :Guardar sistema;
      else (No)
        :Mostrar error: no inscrito;
      endif
    else if (Accion del estudiante?) then (Ver Calificaciones)
      :Mostrar notas con promedio ponderado;
      :Mostrar estado Aprobado o Reprobado;
    else (Actualizar Perfil)
      if (Contrasena actual correcta?) then (Si)
        :Guardar nuevos datos;
        :Guardar sistema;
      else (No)
        :Mostrar error de contrasena;
      endif
    endif

  endif

  :Cerrar Sesion;
  :Disminuir usuarios activos;
  :Guardar sistema;

else (No)
  :Registrar INICIO_SESION ERROR en Bitacora;
  :Mostrar mensaje de credenciales incorrectas;
endif

:Volver a pantalla de Login;

stop

@enduml
